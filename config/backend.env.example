# Backend environment configuration
# Copy to gemini-backend/.env and update the values before running locally or deploying.

# Flask
FLASK_ENV=production
PORT=5001

# Gemini Generative AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=models/gemini-2.5-flash

# Firebase Admin SDK credentials
# Option 1: path to JSON file on disk (preferred for local development)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/serviceAccountKey.json

# Option 2: inline JSON (single line)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Firebase Realtime Database URL (required for live alerts/location features)
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Optional logging override
# LOG_LEVEL=INFO

