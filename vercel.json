{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    },
    {
      "src": "gemini-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "gemini-frontend/dist",
        "buildCommand": "cd gemini-frontend && npm install && npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/gemini-frontend/dist/$1"
    }
  ],
  "github": {
    "silent": false
  }
}