{
  "version": 2,
  "builds": [
    {
      "src": "gemini-backend/app.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.14"
      }
    },
    {
      "src": "gemini-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm run build:vercel"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "gemini-backend/app.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html",
      "status": 200
    }
  ],
  "github": {
    "silent": false
  }
}

